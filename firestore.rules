rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function conversationDoc(conversationId) {
      return get(/databases/$(database)/documents/conversations/$(conversationId));
    }

    function callDoc(callId) {
      return get(/databases/$(database)/documents/calls/$(callId));
    }

    function roomDoc(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId));
    }

    function friendshipDoc(friendshipId) {
      return get(/databases/$(database)/documents/friendships/$(friendshipId));
    }

    function isConversationMember(conversationId) {
      return signedIn() &&
        request.auth.uid in conversationDoc(conversationId).data.members;
    }

    function isCallParticipant(callId) {
      return signedIn() && (
        request.auth.uid == callDoc(callId).data.callerId ||
        request.auth.uid == callDoc(callId).data.calleeId
      );
    }

    function isRoomMember(roomId) {
      return signedIn() &&
        request.auth.uid in roomDoc(roomId).data.members;
    }

    function isFriendshipMember(friendshipId) {
      return signedIn() &&
        request.auth.uid in friendshipDoc(friendshipId).data.members;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if isSelf(uid);
      allow delete: if false;
    }

    match /usernames/{username} {
      allow read: if signedIn();
      allow create, update: if signedIn() &&
        request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /conversations/{conversationId} {
      allow read: if signedIn() &&
        request.auth.uid in resource.data.members;
      allow create: if signedIn() &&
        request.auth.uid in request.resource.data.members;
      allow update: if signedIn() &&
        request.auth.uid in resource.data.members;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isConversationMember(conversationId);
        allow create: if isConversationMember(conversationId) &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if isConversationMember(conversationId) &&
          request.auth.uid == resource.data.senderId;
        allow delete: if false;
      }
    }

    match /calls/{callId} {
      allow read: if signedIn() && (
        request.auth.uid == resource.data.callerId ||
        request.auth.uid == resource.data.calleeId
      );
      allow create: if signedIn() &&
        request.resource.data.callerId == request.auth.uid;
      allow update: if isCallParticipant(callId);
      allow delete: if false;

      match /offerCandidates/{candidateId} {
        allow read, create: if isCallParticipant(callId);
        allow update, delete: if false;
      }

      match /answerCandidates/{candidateId} {
        allow read, create: if isCallParticipant(callId);
        allow update, delete: if false;
      }
    }

    match /friendships/{friendshipId} {
      allow read: if isFriendshipMember(friendshipId);
      allow create: if signedIn() &&
        request.auth.uid in request.resource.data.members &&
        request.resource.data.requesterId == request.auth.uid;
      allow update: if isFriendshipMember(friendshipId);
      allow delete: if false;
    }

    match /rooms/{roomId} {
      allow read: if isRoomMember(roomId);
      allow create: if signedIn() &&
        request.auth.uid in request.resource.data.members &&
        request.resource.data.ownerId == request.auth.uid;
      allow update: if isRoomMember(roomId);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isRoomMember(roomId);
        allow create: if isRoomMember(roomId) &&
          request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /userDailyChallenges/{challengeId} {
      allow read: if signedIn() &&
        request.auth.uid == resource.data.userId;
      allow create, update: if signedIn() &&
        request.auth.uid == request.resource.data.userId;
      allow delete: if false;
    }
  }
}
