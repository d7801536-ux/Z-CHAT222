// =====================================================================
// 1. AUTHENTICATION (Anonymous + LocalStorage)
// =====================================================================
onAuthStateChanged(auth, async (user) => {
    if (user && currentUsername) {
        // User is logged in
        authScreen.classList.add('hidden');
        appScreen.classList.remove('hidden');
        displayUsername.innerText = `@${currentUsername} 🟢`;
        
        // Set user as online
        await setupUserPresence();
        loadUserAvatar();        // Load user avatar
        loadUserTheme();         // Load user theme
        loadUserStatus();        // Load user status
        loadUserContacts();      // Load contacts
        loadUserGroups();        // Load custom groups
        updateStreak();
        loadRooms();
        listenForMessages();
    } else {
        // User needs to login
        authScreen.classList.remove('hidden');
        appScreen.classList.add('hidden');
    }
});

loginBtn.addEventListener('click', async () => {
    const name = usernameInput.value.trim();
    
    // Validation
    if (name.length < 3) {
        usernameInput.classList.add('border-red-500');
        return alert("Username must be at least 3 characters.");
    }
    if (name.length > 20) {
        return alert("Username must be 20 characters or less.");
    }
    if (!/^[a-zA-Z0-9_-]+$/.test(name)) {
        return alert("Username can only contain letters, numbers, underscore, and hyphen.");
    }
    
    usernameInput.classList.remove('border-red-500');
    loginBtn.disabled = true;
    loginBtn.innerText = 'Initializing...';
    
    currentUsername = name;
    localStorage.setItem('og_username', name);
    
    try {
        await signInAnonymously(auth);
    } catch (error) {
        loginBtn.disabled = false;
        loginBtn.innerText = 'Initialize Uplink';
        console.error("Auth Error:", error);
        alert(`Connection failed: ${error?.code || 'unknown'} - ${error?.message || 'Please check Firebase settings (Auth/DB).'} `);
    }
});

document.getElementById('logout-btn').addEventListener('click', async () => {
    if (!confirm('Are you sure you want to logout?')) return;
    
    try {
        localStorage.removeItem('og_username');
        currentUsername = null;
        await signOut(auth);
    } catch (error) {
        console.error("Logout Error:", error);
        alert("Logout failed. Please refresh the page.");
    }
});

// =====================================================================
// 1A. PRESENCE TRACKING (Online/Offline Status)
// =====================================================================
let userStatusMap = {}; // Track online users

async function setupUserPresence() {
    if (!currentUsername) return;
    
    const userStatusRef = ref(db, `users/${currentUsername}`);
    
    // Set user as online
    await set(userStatusRef, {
        username: currentUsername,
        status: 'online',
        lastSeen: serverTimestamp()
    });
    
    // Set offline on disconnect
    onDisconnect(userStatusRef).set({
        username: currentUsername,
        status: 'offline',
        lastSeen: serverTimestamp()
    });
    
    // Listen to all users' status
    const usersRef = ref(db, 'users');
    onValue(usersRef, (snapshot) => {
        userStatusMap = {};
        snapshot.forEach((childSnapshot) => {
            const data = childSnapshot.val();
            userStatusMap[data.username] = data.status;
        });
    });
}

function getUserStatus(username) {
    return userStatusMap[username] || 'offline';
}

// =====================================================================
// 2. ROOM MANAGEMENT
// =====================================================================
const rooms = [
    { id: 'global', name: 'Global Hub', icon: 'globe' },
    { id: 'gaming', name: 'Gaming Squad', icon: 'gamepad-2' },
    { id: 'study', name: 'Exam Prep', icon: 'book-open' }
];
let customGroups = [];

function loadRooms() {
    roomList.innerHTML = '';
    rooms.forEach(room => {
        const btn = document.createElement('button');
        btn.className = `w-full text-left p-3 rounded-lg mb-1 flex items-center gap-3 transition ${room.id === currentRoom ? 'bg-cyan-500/10 border border-cyan-500/30 text-cyan-400' : 'hover:bg-white/5 text-zinc-400'}`;
        btn.innerHTML = `<i data-lucide="${room.icon}" class="w-4 h-4"></i> <span class="font-bold text-sm uppercase tracking-wider">${room.name}</span>`;
        
        btn.addEventListener('click', () => {
            currentRoom = room.id;
            currentRoomName.innerText = room.name;
            loadRooms();
            listenForMessages();
        });
        
        roomList.appendChild(btn);
    });
    
    // Load custom groups
    if (customGroups.length > 0) {
        const groupLabel = document.createElement('div');
        groupLabel.className = 'text-[10px] text-zinc-600 font-bold uppercase px-1 py-2 mt-2';
        groupLabel.innerText = 'Your Groups';
        roomList.appendChild(groupLabel);
        
        customGroups.forEach(group => {
            const btn = document.createElement('button');
            btn.className = `w-full text-left p-3 rounded-lg mb-1 flex items-center justify-between transition ${group.id === currentRoom ? 'bg-cyan-500/10 border border-cyan-500/30 text-cyan-400' : 'hover:bg-white/5 text-zinc-400'}`;
            btn.innerHTML = `
                <div class="flex items-center gap-2">
                    <i data-lucide="users" class="w-4 h-4"></i> 
                    <span class="font-bold text-sm">${group.name}</span>
                </div>
            `;
            
            btn.addEventListener('click', () => {
                currentRoom = group.id;
                currentRoomName.innerText = group.name;
                loadRooms();
                listenForMessages();
            });
            
            roomList.appendChild(btn);
        });
    }
    
    lucide.createIcons();
}

function loadUserGroups() {
    if (!currentUsername) return;
    const groupsRef = ref(db, `userGroups/${currentUsername}`);
    onValue(groupsRef, (snapshot) => {
        customGroups = [];
        snapshot.forEach((child) => {
            customGroups.push({
                id: child.key,
                name: child.val().name || child.key,
                creator: child.val().creator
            });
        });
        loadRooms();
    });
}

// Group Creation Modal
const createGroupModal = document.getElementById('create-group-modal');
const createGroupBtn = document.getElementById('create-group-btn');
const closeGroupModal = document.getElementById('close-group-modal');
const createGroupSubmit = document.getElementById('create-group-submit');
const groupNameInput = document.getElementById('group-name-input');
const groupDescInput = document.getElementById('group-desc-input');

createGroupBtn.addEventListener('click', () => {
    createGroupModal.classList.remove('hidden');
    groupNameInput.focus();
});

closeGroupModal.addEventListener('click', () => {
    createGroupModal.classList.add('hidden');
    groupNameInput.value = '';
    groupDescInput.value = '';
});

createGroupSubmit.addEventListener('click', async () => {
    const name = groupNameInput.value.trim();
    if (!name) {
        alert('Group name is required');
        return;
    }
    
    const groupId = Date.now().toString();
    const desc = groupDescInput.value.trim();
    
    try {
        const groupRef = ref(db, `groups/${groupId}`);
        await set(groupRef, {
            id: groupId,
            name: name,
            description: desc,
            creator: currentUsername,
            createdAt: serverTimestamp(),
            members: { [currentUsername]: true }
        });
        
        const userGroupRef = ref(db, `userGroups/${currentUsername}/${groupId}`);
        await set(userGroupRef, {
            name: name,
            creator: currentUsername,
            joinedAt: serverTimestamp()
        });
        
        createGroupModal.classList.add('hidden');
        groupNameInput.value = '';
        groupDescInput.value = '';
        loadUserGroups();
        alert('Group created successfully!');
    } catch (error) {
        console.error("Failed to create group:", error);
        alert("Failed to create group. Try again.");
    }
});

